    "@types/express-session": "^1.18.0",
    "@types/mssql": "^12.3.0",
    "@types/node": "20.19.27",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "5.6.3",
    "vite": "^7.3.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  },
  "build": {
    "appId": "com.modelhane.app",
    "productName": "Modelhane Planlama",
    "directories": {
      "output": "dist-exe"
    },
    "asar": true,
    "compression": "normal",
    "asarUnpack": [
      "dist/**/*",
      "desktop/**/*",
      ".env",
      "node_modules/**/*"
    ],
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json",
      ".env",
      "!node_modules/**/*",
      "node_modules/@azure/**/*",
      "node_modules/@azure-rest/**/*",
      "node_modules/@js-joda/**/*",
      "node_modules/@supabase/**/*",
      "node_modules/@tediousjs/**/*",
      "node_modules/@types/**/*",
      "node_modules/@typespec/**/*",
      "node_modules/abort-controller/**/*",
      "node_modules/agent-base/**/*",
      "node_modules/argparse/**/*",
      "node_modules/base64-js/**/*",
      "node_modules/bl/**/*",
      "node_modules/buffer/**/*",
      "node_modules/buffer-equal-constant-time/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/bundle-name/**/*",
      "node_modules/commander/**/*",
      "node_modules/debug/**/*",
      "node_modules/default-browser/**/*",
      "node_modules/default-browser-id/**/*",
      "node_modules/define-lazy-prop/**/*",
      "node_modules/dotenv/**/*",
      "node_modules/ecdsa-sig-formatter/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/event-target-shim/**/*",
      "node_modules/events/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/http-proxy-agent/**/*",
      "node_modules/https-proxy-agent/**/*",
      "node_modules/iconv-lite/**/*",
      "node_modules/iceberg-js/**/*",
      "node_modules/ieee754/**/*",
      "node_modules/inherits/**/*",
      "node_modules/is-docker/**/*",
      "node_modules/is-inside-container/**/*",
      "node_modules/is-wsl/**/*",
      "node_modules/js-md4/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/jsonwebtoken/**/*",
      "node_modules/jwa/**/*",
      "node_modules/jws/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.includes/**/*",
      "node_modules/lodash.isboolean/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/lodash.isinteger/**/*",
      "node_modules/lodash.isnumber/**/*",
      "node_modules/lodash.isplainobject/**/*",
      "node_modules/lodash.isstring/**/*",
      "node_modules/lodash.once/**/*",
      "node_modules/ms/**/*",
      "node_modules/mssql/**/*",
      "node_modules/native-duplexpair/**/*",
      "node_modules/open/**/*",
      "node_modules/process/**/*",
      "node_modules/readable-stream/**/*",
      "node_modules/run-applescript/**/*",
      "node_modules/safe-buffer/**/*",
      "node_modules/safer-buffer/**/*",
      "node_modules/sax/**/*",
      "node_modules/semver/**/*",
      "node_modules/sprintf-js/**/*",
      "node_modules/string_decoder/**/*",
      "node_modules/tarn/**/*",
      "node_modules/tedious/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/tslib/**/*",
      "node_modules/undici-types/**/*",
      "node_modules/universalify/**/*",
      "node_modules/wsl-utils/**/*",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": "../.env"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Seyfullah-KIZILKAYAA",
        "repo": "modelhane-kaynak",
        "releaseType": "draft",
        "vPrefixedTagName": true
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "installerLanguages": [
        "tr_TR"
      ],
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Modelhane Planlama"
    }
  }
}